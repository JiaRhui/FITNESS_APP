SONAR_TOKEN=
SONAR_PROJECT_KEY=fitness-app

# =========================
# Jenkins
# =========================
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=

# =========================
# Grafana
# =========================
GRAFANA_ADMIN_USER=admin
